{
	"name": "hotaisle-next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"generate:blog": "bun run scripts/generate_blog_data.ts",
		"generate:static-content": "bun run scripts/generate_static_content_data.ts",
		"generate:search": "bun run scripts/generate_search_data.ts",
		"generate:content": "bun run generate:blog && bun run generate:static-content && bun run generate:search",
		"watch:content": "bun run scripts/watch_content.ts",
		"prebuild": "bun run generate:content",
		"dev": "bun run generate:content && (bun run watch:content & vinext dev)",
		"build": "bun run scripts/build_static.ts",
		"preview": "vinext start",
		"preview:static": "bun run build && bun run scripts/preview_static.ts",
		"deploy": "bun run build && vinext deploy --skip-build",
		"check": "bun ./node_modules/ultracite/dist/index.js check",
		"fix": "bun ./node_modules/ultracite/dist/index.js fix"
	},
	"dependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"clsx": "^2.1.1",
		"gray-matter": "^4.0.3",
		"lucide-react": "^0.577.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-router-dom": "^7.13.1",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-highlight": "^7.0.2",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-html": "^16.0.1",
		"remark-rehype": "^11.1.2",
		"tailwind-merge": "^3.5.0",
		"use-local-storage-state": "^19.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/vite-plugin": "^1.28.0",
		"@tailwindcss/postcss": "^4.2.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitejs/plugin-rsc": "^0.5.21",
		"bun-types": "^1.3.10",
		"rolldown": "^1.0.0-rc.9",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"ultracite": "^7.3.1",
		"vinext": "^0.0.30",
		"vite": "^8.0.0",
		"wrangler": "^4.73.0"
	}
}
