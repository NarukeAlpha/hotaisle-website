{
	"name": "hotaisle-next",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"generate:blog": "bun run scripts/generate_blog_data.ts",
		"generate:images": "bun run scripts/generate_image_variants.ts && bun run scripts/sync_blog_assets.ts",
		"generate:static-content": "bun run scripts/generate_static_content_data.ts",
		"generate:search": "bun run scripts/generate_search_data.ts",
		"generate:content": "bun run generate:blog && bun run generate:images && bun run generate:static-content && bun run generate:search",
		"watch:content": "bun run scripts/watch_content.ts",
		"prebuild": "bun run generate:content",
		"dev": "bun run scripts/ensure_dev_tls.ts && bun run generate:content && (bun run watch:content & vinext dev --port 4174 --hostname localhost)",
		"build": "bun run scripts/build_static.ts",
		"preview": "bun run build && bun run scripts/preview_static.ts",
		"preview:vinext": "vinext start",
		"preview:static": "bun run preview",
		"deploy": "bun run build && bun run wrangler deploy --config wrangler.jsonc",
		"tailwind:lint": "bun run scripts/fix_tailwind_lint.ts",
		"tailwind:lint:dry": "bun run scripts/fix_tailwind_lint.ts --dry-run",
		"lighthouse": "bun run scripts/run_lighthouse.ts",
		"lighthouse:pages": "bun run scripts/generate_lighthouse_pages.ts",
		"check:imports": "bun run scripts/check_import_paths.ts",
		"typecheck": "bun run tsc -b",
		"check": "bun ./node_modules/ultracite/dist/index.js check && bun run check:imports && bun run typecheck",
		"check:finalize": "bun run check && bun run tailwind:lint:dry",
		"fix": "bun ./node_modules/ultracite/dist/index.js fix && bun run tailwind:lint"
	},
	"dependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"clsx": "^2.1.1",
		"gray-matter": "^4.0.3",
		"lucide-react": "^1.8.0",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-router-dom": "^7.14.1",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-highlight": "^7.0.2",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-html": "^16.0.1",
		"remark-rehype": "^11.1.2",
		"tailwind-merge": "^3.5.0",
		"use-local-storage-state": "^19.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@cloudflare/vite-plugin": "^1.32.2",
		"@tailwindcss/language-server": "^0.14.29",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitejs/plugin-rsc": "^0.5.24",
		"bun-types": "^1.3.12",
		"lighthouse": "^13.1.0",
		"rolldown": "^1.0.0-rc.15",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"ultracite": "^7.5.6",
		"vinext": "^0.0.41",
		"vite": "^8.0.8",
		"wrangler": "^4.82.2"
	}
}
