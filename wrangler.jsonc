{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "hotaisle-website",
	"compatibility_date": "2026-04-01",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./src/worker/index.ts",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist-static",
		"html_handling": "auto-trailing-slash",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/machine-status", "/ws"]
	},
	"durable_objects": {
		"bindings": [
			{ "name": "MACHINE_STATUS_HUB", "class_name": "MachineStatusHub" }
		]
	},
	"migrations": [{ "tag": "v1", "new_sqlite_classes": ["MachineStatusHub"] }],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true
		}
	},
	"send_metrics": false,
	"dev": {
		"port": 4174,
		"local_protocol": "https"
	},
	"routes": [
		{
			"pattern": "hotaisle.xyz",
			"custom_domain": true
		},
		{
			"pattern": "www.hotaisle.xyz",
			"custom_domain": true
		},
		{
			"pattern": "blog.hotaisle.xyz",
			"custom_domain": true
		},
		{
			"pattern": "mta-sts.hotaisle.xyz",
			"custom_domain": true
		}
	],
	"images": { "binding": "IMAGES" }
}
