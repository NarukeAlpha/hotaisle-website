{
	"compilerOptions": {
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"outDir": ".tsbuild/node",
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],
		"types": ["node", "bun-types"],
		"skipLibCheck": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"vite.config.ts",
		"scripts/*.ts",
		"src/lib/**/*.ts",
		"src/generated/*.ts",
		"src/vite-env.d.ts"
	]
}
